<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>br.filipegajo.tec-podcast-watch</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/filipegajo/anki-tec/watch-tec-podcast.sh</string>
    </array>

    <!-- Reinicia automaticamente se cair -->
    <key>KeepAlive</key>
    <true/>

    <!-- Inicia junto com o login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Logs -->
    <key>StandardOutPath</key>
    <string>/Users/filipegajo/anki-tec/podcast-watch-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/filipegajo/anki-tec/podcast-watch-stderr.log</string>

    <!-- Variáveis de ambiente necessárias -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>HOME</key>
        <string>/Users/filipegajo</string>
    </dict>

    <!-- Aguarda 5s após login antes de iniciar -->
    <key>ThrottleInterval</key>
    <integer>5</integer>
</dict>
</plist>
